# API Keys (required for AI answers)
GEMINI_API_KEY=AIzaSyBLVcRY6vzWSlJxYZImfWqPYLuGbpSpa8I
LLM_PROVIDER=gemini
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MODEL_FALLBACKS=gemini-2.0-flash,gemini-2.5-flash,gemini-2.0-flash-lite
OPENAI_MODEL=gpt-3.5-turbo

# Backend API
API_HOST=0.0.0.0
API_PORT=8000
BACKEND_URL=http://localhost:8000
# Set true to run RAG inside Streamlit only (no uvicorn needed)
USE_LOCAL_RAG=false
CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501
API_TIMEOUT_SECONDS=300

# Logging
LOG_LEVEL=INFO

# Embeddings & Models
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# Chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Retrieval
TOP_K_RESULTS=4
RETRIEVAL_CANDIDATE_MULTIPLIER=3
HYBRID_ALPHA=0.5
SIMILARITY_THRESHOLD=0.25
MIN_RETRIEVAL_RESULTS=1
MAX_RETRIEVAL_RESULTS=12

# Context budgeting
MAX_CONTEXT_CHARS=12000
MAX_CONTEXT_TOKENS=3000

# Reranking (first query loads a large model; keep false unless you need it)
ENABLE_RERANKING=false
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANK_TOP_K=4
RERANK_TIMEOUT_SECONDS=30

# LLM API timeouts (seconds)
LLM_REQUEST_TIMEOUT_SECONDS=120

# BM25
BM25_K1=1.5
BM25_B=0.75

# Collection
COLLECTION_NAME=documents
